{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "check": "npx tsc --noEmit --watch",
    "============= Pour la base de données ======": "",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:reset": "prisma migrate reset --force",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "node --env-file=.env --import tsx ./prisma/seed.ts",
    "db:reset": "npm run db:migrate:reset && npm run db:migrate:deploy && npm run db:seed"
  },
  "prisma": {
    "seed": "node --env-file=.env ./prisma/seed.ts"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@prisma/adapter-pg": "^7.8.0",
